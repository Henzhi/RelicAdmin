<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.relic.mapper.ArtistMapper">

    <resultMap id="artistResultMap" type="com.relic.entity.Artist">
        <id property="id" column="id"/>
        <result property="nameZh" column="name_zh"/>
        <result property="nameEn" column="name_en"/>
        <result property="birthYear" column="birth_year"/>
        <result property="deathYear" column="death_year"/>
        <result property="dynastyId" column="dynasty_id"/>
        <result property="biography" column="biography"/>
        <result property="baiduUrl" column="baidu_url"/>
        <result property="wikiUrl" column="wiki_url"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectById" resultMap="artistResultMap">
        SELECT * FROM artists WHERE id = #{id}
    </select>

    <select id="selectByPage" resultMap="artistResultMap">
        SELECT * FROM artists
        <where>
            <if test="nameZh != null and nameZh != ''">
                AND name_zh LIKE CONCAT('%', #{nameZh}, '%')
            </if>
            <if test="nameEn != null and nameEn != ''">
                AND name_en LIKE CONCAT('%', #{nameEn}, '%')
            </if>
            <if test="dynastyId != null">
                AND dynasty_id = #{dynastyId}
            </if>
        </where>
        ORDER BY birth_year ASC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByPage" resultType="long">
        SELECT COUNT(*) FROM artists
        <where>
            <if test="nameZh != null and nameZh != ''">
                AND name_zh LIKE CONCAT('%', #{nameZh}, '%')
            </if>
            <if test="nameEn != null and nameEn != ''">
                AND name_en LIKE CONCAT('%', #{nameEn}, '%')
            </if>
            <if test="dynastyId != null">
                AND dynasty_id = #{dynastyId}
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO artists (name_zh, name_en, birth_year, death_year, dynasty_id,
                             biography, baidu_url, wiki_url, created_at, updated_at)
        VALUES (#{nameZh}, #{nameEn}, #{birthYear}, #{deathYear}, #{dynastyId},
                #{biography}, #{baiduUrl}, #{wikiUrl}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update">
        UPDATE artists
        <set>
            <if test="nameZh != null">name_zh = #{nameZh},</if>
            <if test="nameEn != null">name_en = #{nameEn},</if>
            <if test="birthYear != null">birth_year = #{birthYear},</if>
            <if test="deathYear != null">death_year = #{deathYear},</if>
            <if test="dynastyId != null">dynasty_id = #{dynastyId},</if>
            <if test="biography != null">biography = #{biography},</if>
            <if test="baiduUrl != null">baidu_url = #{baiduUrl},</if>
            <if test="wikiUrl != null">wiki_url = #{wikiUrl},</if>
            updated_at = #{updatedAt}
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM artists WHERE id = #{id}
    </delete>

</mapper>
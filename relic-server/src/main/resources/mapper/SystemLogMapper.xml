<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.relic.mapper.SystemLogMapper">

    <sql id="whereClause">
        <where>
            <if test="logLevel != null and logLevel != ''">
                AND log_level = #{logLevel}
            </if>
            <if test="module != null and module != ''">
                AND module = #{module}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (module LIKE CONCAT('%', #{keyword}, '%')
                     OR message LIKE CONCAT('%', #{keyword}, '%')
                     OR detail LIKE CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="startTime != null and startTime != ''">
                AND created_at &gt;= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND created_at &lt;= #{endTime}
            </if>
        </where>
    </sql>

    <select id="selectByPage" resultType="map">
        SELECT id, log_level AS logLevel, module, message, detail, created_at AS createdAt
        FROM system_logs
        <include refid="whereClause"/>
        ORDER BY id DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByPage" resultType="long">
        SELECT COUNT(*) FROM system_logs
        <include refid="whereClause"/>
    </select>

    <select id="selectAllForExport" resultType="map">
        SELECT id, log_level AS logLevel, module, message, detail, created_at AS createdAt
        FROM system_logs
        <include refid="whereClause"/>
        ORDER BY id DESC
    </select>

    <insert id="insert">
        INSERT INTO system_logs (log_level, module, message, detail, created_at)
        VALUES (#{logLevel}, #{module}, #{message}, #{detail}, NOW())
    </insert>

</mapper>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.relic.mapper.AdminUserRoleMapper">

    <insert id="insert">
        INSERT INTO admin_user_role (admin_user_id, role_id, created_at)
        VALUES (#{adminUserId}, #{roleId}, #{createdAt})
    </insert>

    <delete id="deleteByAdminUserId">
        DELETE FROM admin_user_role WHERE admin_user_id = #{adminUserId}
    </delete>

</mapper>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.relic.mapper.PermissionMapper">

    <resultMap id="permissionResultMap" type="com.relic.entity.Permission">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="displayName" column="display_name"/>
        <result property="module" column="module"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectById" resultMap="permissionResultMap">
        SELECT * FROM permissions WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="permissionResultMap">
        SELECT * FROM permissions ORDER BY id ASC
    </select>

    <select id="selectByPage" resultMap="permissionResultMap">
        SELECT * FROM permissions
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="module != null and module != ''">
                AND module = #{module}
            </if>
        </where>
        ORDER BY id ASC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByPage" resultType="long">
        SELECT COUNT(*) FROM permissions
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="module != null and module != ''">
                AND module = #{module}
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO permissions (name, display_name, module, created_at)
        VALUES (#{name}, #{displayName}, #{module}, #{createdAt})
    </insert>

    <update id="update">
        UPDATE permissions
        <set>
            <if test="displayName != null">display_name = #{displayName},</if>
            <if test="module != null">module = #{module},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM permissions WHERE id = #{id}
    </delete>

    <select id="selectByRoleId" resultMap="permissionResultMap">
        SELECT p.* FROM permissions p
        INNER JOIN role_permissions rp ON p.id = rp.permission_id
        WHERE rp.role_id = #{roleId}
    </select>

</mapper>
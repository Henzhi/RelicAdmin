<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.relic.mapper.CommentMapper">
    <resultMap id="commentResultMap" type="com.relic.entity.UserComment">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="artifactId" column="artifact_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="content" column="content"/>
        <result property="likeCount" column="like_count"/>
        <result property="status" column="status"/>
        <result property="auditBy" column="audit_by"/>
        <result property="auditTime" column="audit_time"/>
        <result property="rejectReason" column="reject_reason"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectById" resultMap="commentResultMap">
        SELECT * FROM user_comments WHERE id = #{id}
    </select>

    <select id="selectByPage" resultMap="commentResultMap">
        SELECT * FROM user_comments
        <where>
            <if test="username != null and username != ''">
                AND user_id IN (SELECT id FROM users WHERE username LIKE CONCAT('%', #{username}, '%'))
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="artifactId != null">
                AND artifact_id = #{artifactId}
            </if>
        </where>
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByPage" resultType="long">
        SELECT COUNT(*) FROM user_comments
        <where>
            <if test="username != null and username != ''">
                AND user_id IN (SELECT id FROM users WHERE username LIKE CONCAT('%', #{username}, '%'))
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="artifactId != null">
                AND artifact_id = #{artifactId}
            </if>
        </where>
    </select>

    <update id="updateStatus">
        UPDATE user_comments SET status = #{status}, audit_by = #{auditBy},
        audit_time = #{auditTime}
        <if test="rejectReason != null">, reject_reason = #{rejectReason}</if>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM user_comments WHERE id = #{id}
    </delete>
</mapper>
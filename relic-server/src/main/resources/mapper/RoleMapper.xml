<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.relic.mapper.RoleMapper">

    <resultMap id="roleResultMap" type="com.relic.entity.Role">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="displayName" column="display_name"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectById" resultMap="roleResultMap">
        SELECT * FROM roles WHERE id = #{id}
    </select>

    <select id="selectByName" resultMap="roleResultMap">
        SELECT * FROM roles WHERE name = #{name}
    </select>

    <select id="selectAll" resultMap="roleResultMap">
        SELECT * FROM roles ORDER BY id ASC
    </select>

    <select id="selectByPage" resultMap="roleResultMap">
        SELECT * FROM roles
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
        ORDER BY id ASC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByPage" resultType="long">
        SELECT COUNT(*) FROM roles
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO roles (name, display_name, description, created_at, updated_at)
        VALUES (#{name}, #{displayName}, #{description}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update">
        UPDATE roles
        <set>
            <if test="displayName != null">display_name = #{displayName},</if>
            <if test="description != null">description = #{description},</if>
            updated_at = #{updatedAt}
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM roles WHERE id = #{id}
    </delete>

    <select id="selectByUserId" resultMap="roleResultMap">
        SELECT r.* FROM roles r
        INNER JOIN user_roles ur ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
    </select>

</mapper>
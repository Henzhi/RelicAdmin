# 复制此文件为 .env 并填入真实值（.env 不会被提交到 Git）
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# MySQL
RELIC_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
RELIC_DATASOURCE_HOST=your-mysql-host
RELIC_DATASOURCE_PORT=3306
RELIC_DATASOURCE_DATABASE=your_database
RELIC_DATASOURCE_USERNAME=your_username
RELIC_DATASOURCE_PASSWORD=your_mysql_password

# Redis（Upstash 等云 Redis 通常需要开启 SSL）
RELIC_REDIS_HOST=your-redis-host
RELIC_REDIS_PORT=6379
RELIC_REDIS_PASSWORD=your_redis_password
RELIC_REDIS_DATABASE=0
SPRING_DATA_REDIS_SSL_ENABLED=true
